# =============================================================================
# LIVRABLE 8 — Variables d'environnement documentees
# Copier ce fichier en .env.local et remplir toutes les valeurs
# JAMAIS commiter .env.local dans git (il est dans .gitignore)
# =============================================================================

# =============================================================================
# BASE DE DONNEES — PostgreSQL
# Source : https://neon.tech (gratuit) ou https://supabase.com
# Neon : creer un projet > Dashboard > Connection string
# =============================================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# =============================================================================
# STOREFRONT — Next.js
# NEXT_PUBLIC_ = exposé cote client (navigateur) — ne jamais mettre de secrets
# =============================================================================

# URL publique du storefront (sans slash final)
NEXT_PUBLIC_STORE_URL="https://votredomaine.com"

# Nom de la boutique (affiché dans le titre, footer, emails)
NEXT_PUBLIC_SHOP_NAME="Ma Boutique"

# Description courte pour le SEO (meta description de la page d'accueil)
NEXT_PUBLIC_SHOP_DESCRIPTION="Boutique en ligne premium"

# Template visuel : minimal | dark-premium | bold-color
NEXT_PUBLIC_TEMPLATE="minimal"

# Stripe publishable key (commence par pk_live_ ou pk_test_)
# Source : https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# PayPal Client ID (sandbox ou production)
# Source : https://developer.paypal.com/dashboard/applications
NEXT_PUBLIC_PAYPAL_CLIENT_ID="PAYPAL_CLIENT_ID_ICI"

# Environnement PayPal : sandbox | production
NEXT_PUBLIC_PAYPAL_ENV="sandbox"

# =============================================================================
# STRIPE — Secrets (cote serveur uniquement)
# Source : https://dashboard.stripe.com/apikeys
# =============================================================================

# Cle secrete Stripe (commence par sk_live_ ou sk_test_)
STRIPE_SECRET_KEY="sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Secret du webhook Stripe (commence par whsec_)
# Source : Dashboard Stripe > Webhooks > Votre endpoint > Signing secret
# Evenements a enregistrer : checkout.session.completed, payment_intent.succeeded,
#                            payment_intent.payment_failed, charge.refunded
STRIPE_WEBHOOK_SECRET="whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# =============================================================================
# PAYPAL — Secrets (cote serveur uniquement)
# Source : https://developer.paypal.com/dashboard/applications
# =============================================================================
PAYPAL_CLIENT_ID="PAYPAL_CLIENT_ID_ICI"
PAYPAL_CLIENT_SECRET="PAYPAL_CLIENT_SECRET_ICI"

# ID du webhook PayPal (pour verification de signature)
# Source : Dashboard PayPal > Webhooks > Votre webhook > Webhook ID
PAYPAL_WEBHOOK_ID="PAYPAL_WEBHOOK_ID_ICI"

# Environnement : sandbox | production
PAYPAL_ENV="sandbox"

# =============================================================================
# EMAILS — Resend
# Source : https://resend.com (gratuit jusqu'a 3000 emails/mois)
# Creer un compte > API Keys > Create API Key
# =============================================================================

# Cle API Resend
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Adresse expediteur (doit etre verifiee dans Resend)
EMAIL_FROM="boutique@votredomaine.com"

# Email du commercant pour les alertes nouvelles commandes et stock faible
MERCHANT_EMAIL="commercant@exemple.com"

# =============================================================================
# RATE LIMITING — Upstash Redis
# Source : https://upstash.com (gratuit tier genereux)
# Creer une base Redis > REST API > URL & Token
# Si non configure, rate limiting desactive (ok en dev)
# =============================================================================
UPSTASH_REDIS_REST_URL="https://XXXXXXXX.upstash.io"
UPSTASH_REDIS_REST_TOKEN="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# =============================================================================
# MEDIA / IMAGES — Cloudinary
# Source : https://cloudinary.com (gratuit 25 Go)
# Dashboard > Settings > Access Keys
# =============================================================================
CLOUDINARY_CLOUD_NAME="votre_cloud_name"
CLOUDINARY_API_KEY="XXXXXXXXXXXXXXXXXX"
CLOUDINARY_API_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXX"

# =============================================================================
# PAYLOAD CMS — Back-office Admin
# =============================================================================

# URL publique du serveur Payload (Railway ou Render)
PAYLOAD_PUBLIC_SERVER_URL="https://admin.votredomaine.com"

# Cle secrete Payload (chaine aleatoire d'au moins 32 caracteres)
# Generer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET="GENERER_UNE_CLE_ALEATOIRE_DE_32_CARACTERES_MINIMUM"

# URL du storefront (pour les CORS)
STORE_URL="https://votredomaine.com"

# Domaine du cookie de session (optionnel)
COOKIE_DOMAIN="votredomaine.com"

# Nom de la boutique (utilise dans les emails envoyes depuis l'admin)
SHOP_NAME="Ma Boutique"

# Port du serveur Payload (Railway detecte PORT automatiquement)
PORT="3001"

# =============================================================================
# NEWSLETTER (optionnel)
# Choisir un provider : brevo | mailchimp
# =============================================================================

# Provider : brevo | mailchimp
NEWSLETTER_PROVIDER="brevo"

# Cle API du provider
# Brevo : https://app.brevo.com > Parametres > Cles API
# Mailchimp : https://admin.mailchimp.com > Account > Extras > API keys
NEWSLETTER_API_KEY="votre_cle_api"

# ID de la liste / audience
# Brevo : ID de la liste dans Contacts > Listes
# Mailchimp : ID de l'audience dans Audience > Settings
NEWSLETTER_LIST_ID="123"

# =============================================================================
# NODE
# =============================================================================
NODE_ENV="production"
