// =============================================================================
// LIVRABLE 2 — Schema Prisma complet
// PostgreSQL 15 + Prisma ORM
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum ProductBadge {
  NONE
  NEW
  PROMO
  BESTSELLER
}

enum ProductStatus {
  PUBLISHED
  DRAFT
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  PAYPAL
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PageStatus {
  PUBLISHED
  DRAFT
}

enum UserRole {
  SUPER_ADMIN
  CLIENT_ADMIN
}

// =============================================================================
// PRODUITS
// =============================================================================

model Product {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  description    String?
  descriptionHtml String?      @db.Text
  price          Decimal       @db.Decimal(10, 2)
  compareAtPrice Decimal?      @db.Decimal(10, 2)
  badge          ProductBadge  @default(NONE)
  status         ProductStatus @default(DRAFT)
  totalStock     Int           @default(0)
  seoTitle       String?
  seoDescription String?
  seoImage       String?
  categoryId     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  category    Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images      ProductImage[]
  variants    Variant[]
  orderItems  OrderItem[]
  reviews     Review[]

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
  @@index([totalStock])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  order     Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([order])
}

// =============================================================================
// VARIANTES
// =============================================================================

model Variant {
  id        String  @id @default(cuid())
  productId String
  name      String

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  options VariantOption[]

  @@index([productId])
}

model VariantOption {
  id        String @id @default(cuid())
  variantId String
  label     String
  stock     Int    @default(0)
  sku       String?

  variant    Variant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([variantId])
}

// =============================================================================
// CATEGORIES
// =============================================================================

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  image       String?
  description String?
  order       Int     @default(0)
  parentId    String?

  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  products Product[]

  @@index([slug])
  @@index([parentId])
  @@index([order])
}

// =============================================================================
// CLIENTS / UTILISATEURS BOUTIQUE
// =============================================================================

model Customer {
  id              String    @id @default(cuid())
  email           String    @unique
  firstName       String
  lastName        String
  phone           String?
  passwordHash    String?
  newsletterOptIn Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  addresses CustomerAddress[]
  orders    Order[]

  @@index([email])
  @@index([createdAt])
}

model CustomerAddress {
  id         String  @id @default(cuid())
  customerId String
  firstName  String
  lastName   String
  street     String
  city       String
  zip        String
  country    String  @default("FR")
  isDefault  Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// =============================================================================
// COMMANDES
// =============================================================================

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  status          OrderStatus   @default(PENDING)
  customerId      String?
  guestEmail      String?
  guestFirstName  String?
  guestLastName   String?
  guestPhone      String?

  shippingFirstName  String
  shippingLastName   String
  shippingStreet     String
  shippingCity       String
  shippingZip        String
  shippingCountry    String    @default("FR")

  billingFirstName   String?
  billingLastName    String?
  billingStreet      String?
  billingCity        String?
  billingZip         String?
  billingCountry     String?

  paymentMethod      PaymentMethod
  paymentIntentId    String?
  paymentSessionId   String?

  subtotal           Decimal   @db.Decimal(10, 2)
  discountAmount     Decimal   @default(0) @db.Decimal(10, 2)
  shippingCost       Decimal   @default(0) @db.Decimal(10, 2)
  total              Decimal   @db.Decimal(10, 2)

  couponCode         String?
  shippingOptionName String?
  trackingNumber     String?
  notes              String?   @db.Text

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  customer           Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items              OrderItem[]

  @@index([orderNumber])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentIntentId])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String?
  variantOptionId String?
  productName     String
  variantLabel    String?
  quantity        Int
  unitPrice       Decimal  @db.Decimal(10, 2)
  totalPrice      Decimal  @db.Decimal(10, 2)
  productImage    String?

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantOption VariantOption? @relation(fields: [variantOptionId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

// =============================================================================
// CODES PROMO
// =============================================================================

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  type           CouponType
  value          Decimal    @db.Decimal(10, 2)
  minOrderAmount Decimal?   @db.Decimal(10, 2)
  expiresAt      DateTime?
  maxUses        Int?
  usedCount      Int        @default(0)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())

  @@index([code])
  @@index([isActive])
}

// =============================================================================
// AVIS CLIENTS
// =============================================================================

model Review {
  id          String       @id @default(cuid())
  productId   String
  authorName  String
  authorEmail String
  rating      Int          @db.SmallInt
  comment     String?      @db.Text
  status      ReviewStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([status])
  @@index([rating])
}

// =============================================================================
// PAGES STATIQUES
// =============================================================================

model Page {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  content        Json?
  status         PageStatus @default(DRAFT)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([slug])
  @@index([status])
}

// =============================================================================
// MEDIAS
// =============================================================================

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  size      Int
  alt       String?
  folder    String?
  createdAt DateTime @default(now())

  @@index([folder])
  @@index([mimeType])
}

// =============================================================================
// ARTICLES BLOG (optionnel)
// =============================================================================

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  content     Json?
  coverImage  String?
  category    String?
  author      String?
  status      PageStatus @default(DRAFT)
  publishedAt DateTime?
  seoTitle    String?
  seoDescription String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
}

// =============================================================================
// CONFIGURATION DU SITE (singleton)
// =============================================================================

model SiteConfig {
  id                    String  @id @default("singleton")
  shopName              String  @default("Ma Boutique")
  logoUrl               String?
  faviconUrl            String?
  primaryColor          String  @default("#000000")
  secondaryColor        String  @default("#ffffff")
  fontFamily            String  @default("Inter")
  heroImage             String?
  heroTitle             String?
  heroSubtitle          String?
  heroCtaText           String?
  heroCtaLink           String?
  promoBannerText       String?
  promoBannerBgColor    String  @default("#000000")
  promoBannerTextColor  String  @default("#ffffff")
  promoBannerActive     Boolean @default(false)
  contactEmail          String?
  phone                 String?
  instagramUrl          String?
  facebookUrl           String?
  tiktokUrl             String?
  twitterUrl            String?
  youtubeUrl            String?
  shippingOptions       Json    @default("[]")
  newsletterProvider    String?
  newsletterApiKey      String?
  newsletterListId      String?
  lowStockThreshold     Int     @default(5)
  paginationStyle       String  @default("pagination")
  productsPerPage       Int     @default(12)
  updatedAt             DateTime @updatedAt
}

// =============================================================================
// UTILISATEURS ADMIN (Payload CMS gere aussi ses propres users,
// cette table est pour le compte espace client boutique)
// =============================================================================

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  firstName    String
  lastName     String
  passwordHash String
  role         UserRole @default(CLIENT_ADMIN)
  totpSecret   String?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([role])
}

// =============================================================================
// LOGS D'ACTIVITE ADMIN
// =============================================================================

model AdminActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String
  collection String?
  documentId String?
  diff       Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([collection])
  @@index([createdAt])
}
